# Website Infrastructure Diagram
# Developer Portal - Website Module (prod)

vars: {
  d2-config: {
    layout-engine: elk
    sketch: true
  }
}

direction: right

title: {
  label: Developer Portal - Website Infrastructure (prod)
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
}

users: Users {
  icon: https://icons.terrastruct.com/essentials%2F359-users.svg
  shape: image
}

# DNS Layer
route53: Route 53 {
  icon: https://icons.terrastruct.com/aws%2FNetworking%20&%20Content%20Delivery%2FAmazon-Route-53.svg
  shape: image
}

# CDN Layer
cdn: {
  label: Content Delivery

  cloudfront_website: CloudFront\n(Website - OpenNext) {
    icon: https://icons.terrastruct.com/aws%2FNetworking%20&%20Content%20Delivery%2FAmazon-CloudFront.svg
    shape: image
  }

  cloudfront_static: CloudFront\n(Static Contents) {
    icon: https://icons.terrastruct.com/aws%2FNetworking%20&%20Content%20Delivery%2FAmazon-CloudFront.svg
    shape: image
  }

  cf_function: CloudFront\nFunction\n(Viewer Request) {
    icon: https://icons.terrastruct.com/aws%2FNetworking%20&%20Content%20Delivery%2FAmazon-CloudFront.svg
    shape: image
  }
}

# Compute Layer (OpenNext)
compute: {
  label: Compute (OpenNext)

  lambda_server: Lambda\n(Server) {
    icon: https://icons.terrastruct.com/aws%2FCompute%2FAWS-Lambda.svg
    shape: image
  }

  lambda_initializer: Lambda\n(Initializer) {
    icon: https://icons.terrastruct.com/aws%2FCompute%2FAWS-Lambda.svg
    shape: image
  }
}

# Auth Layer
auth: {
  label: Authentication

  cognito_pool: Cognito\nUser Pool {
    icon: https://icons.terrastruct.com/aws%2FSecurity%2C%20Identity%2C%20&%20Compliance%2FAmazon-Cognito.svg
    shape: image
  }

  cognito_identity: Cognito\nIdentity Pool {
    icon: https://icons.terrastruct.com/aws%2FSecurity%2C%20Identity%2C%20&%20Compliance%2FAmazon-Cognito.svg
    shape: image
  }
}

# Cognito Lambda Triggers
cognito_lambdas: {
  label: Cognito Lambda Triggers

  custom_message: Lambda\n(Custom Message) {
    icon: https://icons.terrastruct.com/aws%2FCompute%2FAWS-Lambda.svg
    shape: image
  }

  post_confirmation: Lambda\n(Post Confirmation) {
    icon: https://icons.terrastruct.com/aws%2FCompute%2FAWS-Lambda.svg
    shape: image
  }

  define_auth: Lambda\n(Define Auth\nChallenge) {
    icon: https://icons.terrastruct.com/aws%2FCompute%2FAWS-Lambda.svg
    shape: image
  }

  create_auth: Lambda\n(Create Auth\nChallenge) {
    icon: https://icons.terrastruct.com/aws%2FCompute%2FAWS-Lambda.svg
    shape: image
  }

  verify_auth: Lambda\n(Verify Auth\nChallenge) {
    icon: https://icons.terrastruct.com/aws%2FCompute%2FAWS-Lambda.svg
    shape: image
  }
}

# Storage Layer
storage: {
  label: Storage

  s3_static: S3\n(devportal-p-website\n-static-content) {
    icon: https://icons.terrastruct.com/aws%2FStorage%2FAmazon-Simple-Storage-Service-S3.svg
    shape: image
  }

  s3_assets: S3\n(OpenNext Assets) {
    icon: https://icons.terrastruct.com/aws%2FStorage%2FAmazon-Simple-Storage-Service-S3.svg
    shape: image
  }

  s3_lambda_code: S3\n(Lambda Code) {
    icon: https://icons.terrastruct.com/aws%2FStorage%2FAmazon-Simple-Storage-Service-S3.svg
    shape: image
  }
}

# DynamoDB Tables
dynamodb: {
  label: DynamoDB Tables

  questions: DynamoDB\n(WebinarQuestions) {
    icon: https://icons.terrastruct.com/aws%2FDatabase%2FAmazon-DynamoDB.svg
    shape: image
  }

  subscriptions: DynamoDB\n(WebinarSubscriptions)\n(DDB Stream enabled) {
    icon: https://icons.terrastruct.com/aws%2FDatabase%2FAmazon-DynamoDB.svg
    shape: image
  }
}

# Email
ses: SES\n(Email) {
  icon: https://icons.terrastruct.com/aws%2FCustomer%20Engagement%2FAmazon-Simple-Email-Service-SES.svg
  shape: image
}

# SSM Parameters
ssm: SSM\nParameter Store\n(Secrets & Config) {
  icon: https://icons.terrastruct.com/aws%2FManagement%20&%20Governance%2FAWS-Systems-Manager_Parameter-Store.svg
  shape: image
}

# Monitoring
monitoring: {
  label: Monitoring

  cloudwatch: CloudWatch {
    icon: https://icons.terrastruct.com/aws%2FManagement%20&%20Governance%2FAmazon-CloudWatch.svg
    shape: image
  }

  sns: SNS\n(Metric Alarms) {
    icon: https://icons.terrastruct.com/aws%2FApplication%20Integration%2FAmazon-Simple-Notification-Service-SNS.svg
    shape: image
  }
}

# CMS connection (external to this module)
cms_alb: CMS Internal ALB\n(Strapi API\nPort 8080) {
  icon: https://icons.terrastruct.com/aws%2FNetworking%20&%20Content%20Delivery%2FElastic-Load-Balancing.svg
  shape: image
  style.opacity: 0.6
}

# --- Connections ---

users -> route53: HTTPS
route53 -> cdn.cloudfront_website: developer.pagopa.it
route53 -> cdn.cloudfront_static: static-contents.developer.pagopa.it
route53 -> auth.cognito_pool: auth.developer.pagopa.it

cdn.cloudfront_website -> compute.lambda_server: Origin
cdn.cloudfront_website -> storage.s3_assets: Static Assets
cdn.cf_function -> cdn.cloudfront_website: Viewer Request

cdn.cloudfront_static -> storage.s3_static: Origin (OAI)

compute.lambda_server -> storage.s3_static: Read docs/guides
compute.lambda_server -> cms_alb: Fetch CMS content\n(port 8080)
compute.lambda_server -> ssm: Read config\n(STRAPI_API_TOKEN etc.)
compute.lambda_initializer -> compute.lambda_server: Initialize

auth.cognito_pool -> cognito_lambdas.custom_message: Trigger
auth.cognito_pool -> cognito_lambdas.post_confirmation: Trigger
auth.cognito_pool -> cognito_lambdas.define_auth: Trigger
auth.cognito_pool -> cognito_lambdas.create_auth: Trigger
auth.cognito_pool -> cognito_lambdas.verify_auth: Trigger
auth.cognito_identity -> auth.cognito_pool: Federation

cognito_lambdas.post_confirmation -> ses: Send welcome email
cognito_lambdas.create_auth -> ses: Send OTP email

monitoring.cloudwatch -> monitoring.sns: Alarm
