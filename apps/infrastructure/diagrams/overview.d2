# --- Connections ---

# User flows
users -> route53: HTTPS
admins -> route53: HTTPS
broadcaster -> video.ivs: RTMP Stream

route53 -> website.cloudfront: developer.pagopa.it
route53 -> website.cloudfront_static: static-contents.developer.pagopa.it
route53 -> vpc.cms.alb_public: cms.developer.pagopa.it
route53 -> vpc.chatbot.waf: api.chatbot.developer.pagopa.it
route53 -> video.cloudfront_video: video.developer.pagopa.it

# Website internals
website.cloudfront -> website.lambda: Origin
website.cloudfront -> website.s3_assets: Static assets
website.cloudfront_static -> website.s3: Origin
website.lambda -> vpc.cms.alb_internal: Fetch content\n(Internal ALB, port 8080)
website.lambda -> website.s3: Read docs/guides
website.cognito -> ses: Verification emails

# CMS internals
vpc.cms.alb_public -> vpc.cms.ecs_strapi: Port 1337
vpc.cms.alb_internal -> vpc.cms.ecs_strapi: Port 1337
vpc.cms.ecs_strapi -> vpc.cms.rds_cms: PostgreSQL
vpc.cms.ecs_strapi -> vpc.cms.s3_media: Upload media
vpc.cms.cloudfront_media -> vpc.cms.s3_media: Origin (OAI)

# Chatbot internals
vpc.chatbot.waf -> vpc.chatbot.apigw
vpc.chatbot.apigw -> website.cognito: Authorize
vpc.chatbot.apigw -> vpc.chatbot.lambda_api: Invoke (AWS_PROXY)
vpc.chatbot.lambda_api -> vpc.chatbot.nlb: Redis\n(Port 6379)
vpc.chatbot.nlb -> vpc.chatbot.redis
vpc.chatbot.lambda_api -> vpc.chatbot.dynamodb_chatbot: Read/Write
vpc.chatbot.lambda_api -> vpc.chatbot.s3_kb: Read/Write
vpc.chatbot.lambda_api -> vpc.chatbot.sqs: Send evaluate msgs
vpc.chatbot.lambda_api -> vpc.chatbot.langfuse: Traces\n(Internal ALB)
vpc.chatbot.lambda_api -> google: AI Generation
vpc.chatbot.sqs -> vpc.chatbot.lambda_evaluate: Trigger
vpc.chatbot.lambda_evaluate -> vpc.chatbot.langfuse: Evaluate traces
vpc.chatbot.langfuse -> vpc.chatbot.rds_langfuse: PostgreSQL
vpc.chatbot.redis -> vpc.chatbot.efs: Persistent storage

# Index Lambda triggered by S3
website.s3 -> vpc.chatbot.lambda_index: S3 Event (.md files)
vpc.chatbot.lambda_index -> vpc.chatbot.nlb: Update index\n(Redis)
vpc.chatbot.lambda_index -> google: Embeddings

# Active Campaign flow
website.cognito -> ac.eventbridge_rule: User events\n(via CloudTrail)
website.dynamodb_subscriptions -> ac.eventbridge_pipe: DDB Stream\n(Subscriptions)
ac.eventbridge_rule -> ac.sqs_ac: Send message
ac.eventbridge_pipe -> ac.sqs_ac: Transform & send
ac.sqs_ac -> ac.lambda_sync: Trigger
ac.lambda_sync -> ac_external: Sync contacts

# Video Streaming
video.ivs -> video.s3_recordings: Auto-record
video.cloudfront_video -> video.s3_recordings: Origin (OAC)
video.s3_recordings -> video.lambda_video: S3 Event\n(recording-ended.json)
video.lambda_video -> vpc.cms.ecs_strapi: Update webinar\nrecording URL
video.apigw_metrics -> video.lambda_metrics: Invoke
video.lambda_metrics -> video.ivs: Get stream metrics

# Monitoring
website.lambda -> cloudwatch: Logs
vpc.chatbot.lambda_api -> cloudwatch: Logs
vpc.cms.ecs_strapi -> cloudwatch: Logs
